# macOS
.DS_Store

# Editor/IDE
.vscode/
.Rproj.user/

# R session
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Renviron

# R CMD check
*.Rcheck/
*.tar.gz

# knitr / rmarkdown cache
*_cache/
cache/
.quarto/

# R binary outputs (regenerated by simulations)
*.rds
*.Rds
*.rda
*.RData
*.Rdata
*.qs
*.fst

# Logs and scratch
logs/
results/logs/
log_*.txt
results/**/*.txt

# Simulation outputs are not shipped -- nothing under results/ is committed;
# reproduce by running scripts/run_sim_<N>_*.sh (see results/README.md).
results/**/*.Rdata
results/**/*.xlsx
results/**/*.csv
results/**/*.json
results/exports/

# Figures are regenerated by R/plot_sim_figures.R
results/figures/*.pdf

# LaTeX table fragments are regenerated by R/generate_paper_tables.R /
# simulations/sim_motivating.R
results/tables/*.tex

# Stray outputs in repo root
*.pdf
*.xlsx
